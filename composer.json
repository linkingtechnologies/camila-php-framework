{
    "require": {
        "php": "^8.3",
        "ext-curl": "*",
        "ext-exif": "*",
        "ext-fileinfo": "*",
        "ext-gd": "*",
        "ext-mbstring": "*",
        "ext-mysqli": "*",
        "ext-openssl": "*",
        "ext-pdo_mysql": "*",
        "ext-pdo_sqlite": "*",
        "ext-sqlite3": "*",
        "ext-xsl": "*",
        "ext-zip": "*",
        "adodb/adodb-php": "dev-master",
        "amenadiel/jpgraph": "^4.1",
        "bordercloud/sparql": "2.1.0",
        "ezyang/htmlpurifier": "4.18.0",
        "lebedevsergey/odt2xhtml": "1.0",
        "mpdf/mpdf": "*",
        "neitanod/forceutf8": "~2.0",
        "nyholm/psr7": "*",
        "nyholm/psr7-server": "*",
        "phpoffice/phpspreadsheet": "5.1.0",
        "phpoffice/phpword": "*",
        "phpseclib/phpseclib": "~3.0",
        "psr/http-factory": "*",
        "psr/http-message": "*",
        "psr/http-server-handler": "*",
        "psr/http-server-middleware": "*",
        "rospdf/pdf-php": "0.12.67",
        "tinybutstrong/tinybutstrong": "3.15.2",
        "wizaplace/php-etl": "2.3.0"
    },
	"config": {
        "platform": {
            "php": "8.3"
        },
		"preferred-install": "dist",
		"sort-packages": true,
		"optimize-autoloader": true,
		"discard-changes": true
    },
	"archive": {
		"exclude": [
			"*/tests/*",
			"*/docs/*",
			"*/examples/*",
			"*/.github/*",
			"*/.git/*",
			"*/.gitignore",
			"*/.travis.yml",
			"*/phpunit.xml*",
			"*/composer.json",
			"*/composer.lock",
			"*/README*",
			"*/CHANGELOG*"
		]
	}
}
